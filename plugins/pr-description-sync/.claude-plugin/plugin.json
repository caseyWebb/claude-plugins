{
  "name": "pr-description-sync",
  "version": "1.0.1",
  "description": "Reminds Claude to update PR title and description after git push",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/.claude-plugin/hooks/pr-description-sync.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
