{
  "name": "doc-gate",
  "version": "1.1.0",
  "description": "Blocks Claude at stop to review docs with update-when frontmatter for staleness",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/.claude-plugin/hooks/doc-gate.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
